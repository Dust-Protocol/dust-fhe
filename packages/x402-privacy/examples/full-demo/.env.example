# @x402/privacy Full Demo — Environment Variables
#
# Required: A single private key that controls the demo wallet.
# This wallet needs:
#   - ~0.01 ETH on Base Sepolia (for gas)
#   - ~1 USDC on Base Sepolia (for the deposit)
#
# Get testnet funds:
#   ETH:  https://www.alchemy.com/faucets/base-sepolia
#   USDC: https://faucet.circle.com (select Base Sepolia)

PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: custom RPC (default: https://sepolia.base.org)
# BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
